<Window x:Class="Space.OS.Terminal.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalon="clr-namespace:ICSharpCode.AvalonEdit;assembly=ICSharpCode.AvalonEdit"
        mc:Ignorable="d"
        Title="Space.OS.Terminal"
        Height="860"
        Width="1440"
        MinHeight="700"
        MinWidth="1100"
        Background="{StaticResource BgRootBrush}">
    <Window.Resources>
        <!-- Иконки отладки: компактные path, Foreground как у кнопки (в т.ч. disabled). -->
        <Style x:Key="DebugToolbarButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinWidth" Value="32" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.Background>
            <RadialGradientBrush RadiusX="1.1" RadiusY="1.1" GradientOrigin="0.5,0.3">
                <GradientStop Color="#152553" Offset="0" />
                <GradientStop Color="#0A1332" Offset="0.45" />
                <GradientStop Color="#05081A" Offset="1" />
            </RadialGradientBrush>
        </Grid.Background>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="290" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#2B3A75" BorderThickness="0,0,1,0" Background="#0D1431">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" Margin="10" DockPanel.Dock="Top">
                    <Button x:Name="ToggleSidebarButton" Width="42" Height="30" Click="ToggleSidebar_Click">☰</Button>
                    <TextBlock Margin="8,5,0,0" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Space.OS.Terminal</TextBlock>
                </StackPanel>
                <TreeView x:Name="NavigationTree" Margin="8" SelectedItemChanged="NavigationTree_SelectedItemChanged">
                    <TreeViewItem Header="Space" IsExpanded="True">
                        <TreeViewItem Header="Storage" Tag="space-storage" />
                        <TreeViewItem Header="Startup Exes" Tag="space-executionunits" />
                        <TreeViewItem Header="Code editor" Tag="space-code-editor" />
                        <TreeViewItem Header="Vault: Items" Tag="space-vault" />
                    </TreeViewItem>
                    <TreeViewItem Header="Monitor" IsExpanded="True">
                        <TreeViewItem Header="Exes" Tag="monitor-exes" />
                        <TreeViewItem Header="Streams" Tag="monitor-streams" />
                        <TreeViewItem Header="Drivers" Tag="monitor-drivers" />
                        <TreeViewItem Header="Connections" Tag="monitor-connections" />
                    </TreeViewItem>
                    <TreeViewItem Header="Console" IsExpanded="True">
                        <TreeViewItem Header="Logs" Tag="console-logs" />
                    </TreeViewItem>
                </TreeView>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="14">
            <Border CornerRadius="14" Background="#0D1430" BorderBrush="#2D3C79" BorderThickness="1" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock x:Name="SectionTitle" FontSize="24" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}">Startup Exes</TextBlock>
                <TextBlock x:Name="SectionMeta" Margin="14,7,0,0" Foreground="{StaticResource TextMutedBrush}">ready</TextBlock>
            </StackPanel>

            <Grid Margin="16,54,16,16">
                <Grid x:Name="ExecutionUnitsPanel" Visibility="Visible">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ExecutionUnitsReload_Click">Reload</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsAdd_Click">Add</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsDelete_Click">Delete</Button>
                        <Button Margin="8,0,0,0" Click="ExecutionUnitsSave_Click">Save</Button>
                    </StackPanel>
                    <DataGrid x:Name="ExecutionUnitsGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*" />
                            <DataGridTextColumn Header="InstanceCount" Binding="{Binding InstanceCount}" Width="140" />
                            <DataGridTemplateColumn Header="" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Edit" FontSize="11" Padding="8,2" Click="ExecutionUnitsRowEdit_Click" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="StoragePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="StorageReload_Click">Reload</Button>
                        <TextBlock Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">All .agi files under SPACE_PATH</TextBlock>
                    </StackPanel>
                    <TreeView x:Name="StorageTree" Grid.Row="1" Margin="0,10,0,0"
                              Background="#0C1332" Foreground="#DDE8FF" BorderBrush="#3A4A8A" />
                </Grid>

                <Grid x:Name="CodeEditorPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="CodeEditorReload_Click">Reload</Button>
                        <Button Margin="8,0,0,0" Click="CodeEditorSave_Click">Save</Button>
                        <Button Margin="8,0,0,0" Click="CodeEditorDebug_Click">Debug</Button>
                        <Button x:Name="DebugContinueButton" Style="{StaticResource DebugToolbarButton}" Margin="8,0,0,0" IsEnabled="False" Click="DebugContinue_Click"
                                ToolTip="Continue (F5)">
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="M 3,2 L 13,8 3,14 Z" />
                            </Viewbox>
                        </Button>
                        <Button x:Name="DebugStepButton" Style="{StaticResource DebugToolbarButton}" IsEnabled="False" Click="DebugStep_Click"
                                ToolTip="Next source line">
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Canvas Width="16" Height="16">
                                    <!-- линия «текущая строка», стрелка вниз — следующая строка -->
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.35" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 2,5 H 14 M 8,5 V 11 M 5,8 L 8,11 L 11,8" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="DebugStepIntoButton" Style="{StaticResource DebugToolbarButton}" IsEnabled="False" Click="DebugStepInto_Click"
                                ToolTip="Step into — one instruction (F11)">
                            <Viewbox Width="14" Height="14" Stretch="Uniform">
                                <Canvas Width="16" Height="16">
                                    <Path Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                          StrokeThickness="1.35" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 8,2 V 9 M 5,6 L 8,9 L 11,6 M 3.5,12.5 H 12.5" />
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="DebugStopButton" Style="{StaticResource DebugToolbarButton}" IsEnabled="False" Click="DebugStop_Click"
                                ToolTip="Stop debugging">
                            <Viewbox Width="12" Height="12" Stretch="Uniform">
                                <Path Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      Data="M 3,3 H 13 V 13 H 3 Z" />
                            </Viewbox>
                        </Button>
                        <TextBlock x:Name="CodeEditorFileText" Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">No file selected</TextBlock>
                    </StackPanel>
                    <avalon:TextEditor x:Name="CodeEditor"
                                       Grid.Row="1"
                                       Margin="0,10,0,0"
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       ShowLineNumbers="True"
                                       Foreground="#DDE8FF"
                                       Background="#0C1332"
                                       HorizontalScrollBarVisibility="Auto"
                                       VerticalScrollBarVisibility="Auto"
                                       WordWrap="False" />
                </Grid>

                <Grid x:Name="VaultPanel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="460" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.ColumnSpan="2" Orientation="Horizontal">
                        <Button Click="VaultReload_Click">Reload</Button>
                        <Button Margin="8,0,0,0" Click="VaultAdd_Click">Add Item</Button>
                        <Button Margin="8,0,0,0" Click="VaultDelete_Click">Delete Item</Button>
                        <Button Margin="8,0,0,0" Click="VaultSave_Click">Save</Button>
                        <CheckBox x:Name="ShowSensitiveCheckBox" Margin="14,5,0,0" Checked="ShowSensitiveChanged" Unchecked="ShowSensitiveChanged">Show sensitive</CheckBox>
                    </StackPanel>
                    <DataGrid x:Name="VaultItemsGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionChanged="VaultItemsGrid_SelectionChanged"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Program" Binding="{Binding Program}" Width="110" />
                            <DataGridTextColumn Header="System" Binding="{Binding System}" Width="110" />
                            <DataGridTextColumn Header="Module" Binding="{Binding Module}" Width="110" />
                            <DataGridTextColumn Header="Instance" Binding="{Binding InstanceIndex}" Width="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DataGrid x:Name="VaultStoreGrid" Grid.Column="1" Grid.Row="1" Margin="12,0,0,0" AutoGenerateColumns="False" CanUserAddRows="True"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Key" Binding="{Binding Key}" Width="200" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                            <DataGridCheckBoxColumn Header="Sensitive" Binding="{Binding IsSensitive}" Width="95" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="MonitorPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="MonitorRefresh_Click">Refresh</Button>
                        <TextBlock x:Name="MonitorStatsText" Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">stats</TextBlock>
                    </StackPanel>
                    <DataGrid x:Name="MonitorGrid" Grid.Row="1" Margin="0,10,0,0" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                              Background="#111A3F" Foreground="#EAF1FF" BorderBrush="#3A4A8A">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="220" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="220" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" />
                            <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid x:Name="ConsolePanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Button Click="ConsoleRefresh_Click">Refresh</Button>
                        <Button Margin="8,0,0,0" Click="ConsoleClear_Click">Clear</Button>
                        <TextBlock Margin="12,6,0,0" Foreground="{StaticResource TextMutedBrush}">Live console + interpreter print output</TextBlock>
                    </StackPanel>
                    <!-- ListBox только выделяет целую строку; для копирования фрагмента нужен TextBox. -->
                    <TextBox x:Name="ConsoleLogsTextBox" Grid.Row="1" Margin="0,10,0,0"
                             Background="#0C1332" Foreground="#DDE8FF" BorderBrush="#3A4A8A" CaretBrush="#DDE8FF"
                             FontFamily="Consolas" FontSize="13"
                             IsReadOnly="True" IsReadOnlyCaretVisible="True"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" Padding="8,6" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
