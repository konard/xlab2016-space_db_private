<Window x:Class="Space.OS.Terminal.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Width="980"
        Height="620"
        ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="20" Background="#050814" BorderBrush="#2B3A75" BorderThickness="1">
        <Grid>
            <Grid.Background>
                <RadialGradientBrush RadiusX="0.9" RadiusY="0.9" GradientOrigin="0.5,0.45">
                    <GradientStop Color="#1A2B66" Offset="0.0" />
                    <GradientStop Color="#0A1134" Offset="0.52" />
                    <GradientStop Color="#040716" Offset="1.0" />
                </RadialGradientBrush>
            </Grid.Background>
            <Grid.RenderTransform>
                <ScaleTransform x:Name="SplashScale" ScaleX="0.96" ScaleY="0.96" />
            </Grid.RenderTransform>

            <Canvas>
                <Ellipse Width="340" Height="340" Canvas.Left="160" Canvas.Top="80" StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#66B7FF" Offset="0" />
                            <GradientStop Color="#AF7CFF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
                <Ellipse Width="340" Height="340" Canvas.Left="460" Canvas.Top="80" StrokeThickness="2">
                    <Ellipse.Stroke>
                        <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                            <GradientStop Color="#AF7CFF" Offset="0" />
                            <GradientStop Color="#66B7FF" Offset="1" />
                        </LinearGradientBrush>
                    </Ellipse.Stroke>
                </Ellipse>
            </Canvas>

            <TextBlock HorizontalAlignment="Center" Margin="0,350,0,0" VerticalAlignment="Top"
                       FontSize="86" FontWeight="Bold" Foreground="#EEF3FF" Text="SPACE" />
            <TextBlock HorizontalAlignment="Center" Margin="0,452,0,0" VerticalAlignment="Top"
                       FontSize="28" Foreground="#BFD0F9" Text="JOIN UNIVERSE" />

            <Rectangle Height="3" VerticalAlignment="Bottom" Margin="180,0,180,56" RadiusX="2" RadiusY="2">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4FA6FF" Offset="0" />
                        <GradientStop Color="#BB6CFF" Offset="1" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>
        </Grid>
    </Border>
</Window>
